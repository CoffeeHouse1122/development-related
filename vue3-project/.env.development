# 开发环境 API 基础路径（会被代理到 localhost）
VITE_API_BASE_URL=/

# 开发环境 API 代理目标（本地开发服务器地址）
VITE_API_PROXY_TARGET=http://localhost:3000

# CDN 基础路径（开发环境使用相对路径）
VITE_CDN_BASE=./

# API 请求超时时间（毫秒）
VITE_API_TIMEOUT=10000

# 默认语言区域（用于国际化）
VITE_DEFAULT_LOCALE=zh-CN

# 是否启用埋点/数据跟踪
VITE_TRACKER_ENABLED=true

# 是否启用旧浏览器兼容插件（开发环境通常不需要）
VITE_LEGACY=false